# Same OpenRouter key already used by the Supabase refine-reply Edge
# Function (supabase/functions/refine-reply/index.ts) - copy the value from
# the main project's .env, don't create a second one.
OPENROUTER_API_KEY=

# Shared secret n8n must send back as the X-Service-Secret header on every
# call to this service. Generate a random value, e.g.:
#   openssl rand -hex 32
# Same pattern as N8N_WEBHOOK_SECRET, already used elsewhere in this project
# for the approve-reply -> n8n webhook.
AI_SERVICE_SECRET=

# Used only by /consolidate-corrections (reads reply_corrections, writes
# learned_patterns via the Supabase REST API - this service has no other
# direct Supabase access). Same Supabase project, same service-role access
# already used by the project's Edge Functions - copy the values from the
# main project's .env, don't create new ones.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
